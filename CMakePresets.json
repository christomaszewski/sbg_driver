{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 22, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "release",
      "inherits": "base",
      "displayName": "Release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "dev",
      "inherits": "base",
      "displayName": "Debug + ASan/UBSan",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "SBG_ENABLE_ASAN": "ON"
      }
    },
    {
      "name": "dev-tsan",
      "inherits": "base",
      "displayName": "Debug + TSan",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "SBG_ENABLE_TSAN": "ON"
      }
    },
    {
      "name": "release-coverage",
      "inherits": "base",
      "displayName": "Coverage (RelWithDebInfo + --coverage)",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "SBG_ENABLE_COVERAGE": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "release",          "configurePreset": "release" },
    { "name": "dev",              "configurePreset": "dev" },
    { "name": "dev-tsan",         "configurePreset": "dev-tsan" },
    { "name": "release-coverage", "configurePreset": "release-coverage" }
  ],
  "testPresets": [
    {
      "name": "dev",
      "configurePreset": "dev",
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error", "stopOnFailure": false }
    },
    {
      "name": "release-coverage",
      "configurePreset": "release-coverage",
      "output": { "outputOnFailure": true }
    }
  ]
}
