root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cpp,cc,cxx,hpp,h,hh,hxx,c}]
indent_size = 2

[*.{py}]
indent_size = 4

[*.{yaml,yml,json}]
indent_size = 2

[*.{cmake,txt}]
indent_size = 2

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false
