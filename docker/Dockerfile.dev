# Dev environment for sbg_driver. Mirrored exactly by .devcontainer.json so
# every developer (and CI, via Dockerfile.ci) gets the same toolchain.
#
# Base: ROS 2 Lyrical Luth on Ubuntu 26.04 (Resolute). We use ros:lyrical-ros-base
# rather than osrf/ros:lyrical-desktop because:
#   1. ros: namespace publishes multi-arch (amd64 + arm64) — native on Apple Silicon
#   2. desktop packages (rviz2, rqt) aren't needed in the dev image; they live
#      in compose.replay.yaml's separate viz container if needed
ARG ROS_DISTRO=lyrical
FROM ros:${ROS_DISTRO}-ros-base AS dev

ARG DEBIAN_FRONTEND=noninteractive
ARG ROS_DISTRO

# --- System dev tooling -----------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
      build-essential \
      cmake \
      ninja-build \
      git \
      curl \
      wget \
      ca-certificates \
      gdb \
      lldb \
      valgrind \
      lcov \
      gcovr \
      clang-format \
      clang-tidy \
      clang-tools \
      python3-pip \
      python3-colcon-common-extensions \
      python3-colcon-clean \
      python3-colcon-mixin \
      python3-vcstool \
      python3-rosdep \
      doxygen \
      graphviz \
      sudo \
      tmux \
      vim-nox \
    && rm -rf /var/lib/apt/lists/*

# --- ROS 2 packages we depend on -------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
      ros-${ROS_DISTRO}-rclcpp \
      ros-${ROS_DISTRO}-rclcpp-lifecycle \
      ros-${ROS_DISTRO}-rclcpp-components \
      ros-${ROS_DISTRO}-lifecycle-msgs \
      ros-${ROS_DISTRO}-sensor-msgs \
      ros-${ROS_DISTRO}-geometry-msgs \
      ros-${ROS_DISTRO}-nav-msgs \
      ros-${ROS_DISTRO}-std-msgs \
      ros-${ROS_DISTRO}-std-srvs \
      ros-${ROS_DISTRO}-diagnostic-msgs \
      ros-${ROS_DISTRO}-diagnostic-updater \
      ros-${ROS_DISTRO}-tf2 \
      ros-${ROS_DISTRO}-tf2-ros \
      ros-${ROS_DISTRO}-generate-parameter-library \
      ros-${ROS_DISTRO}-launch-testing-ament-cmake \
      ros-${ROS_DISTRO}-launch-testing-ros \
      ros-${ROS_DISTRO}-ament-cmake-gtest \
      ros-${ROS_DISTRO}-ament-lint-auto \
      ros-${ROS_DISTRO}-ament-lint-common \
      ros-${ROS_DISTRO}-ament-clang-format \
      ros-${ROS_DISTRO}-ament-clang-tidy \
      ros-${ROS_DISTRO}-rosidl-default-generators \
      ros-${ROS_DISTRO}-rosidl-default-runtime \
    && rm -rf /var/lib/apt/lists/*

# --- Non-root dev user ------------------------------------------------------
# The base image ships a default `ubuntu` user at UID/GID 1000. Three cases:
#   1. Host UID/GID match 1000 → reuse the existing user (rename to ${USER})
#   2. Host UID/GID differ      → modify the existing user's IDs to match
#   3. ${USER} already exists with the right name → no-op
# Result: one passwordless-sudo dev user in groups dialout/sudo/plugdev,
# regardless of which host invoked the build.
ARG USER=dev
ARG UID=1000
ARG GID=1000
RUN set -eux; \
    # If the target name doesn't exist, but UID 1000 does, rename it.
    if ! id -u "${USER}" >/dev/null 2>&1; then \
      existing="$(getent passwd 1000 | cut -d: -f1 || true)"; \
      if [ -n "${existing}" ]; then \
        existing_group="$(getent group 1000 | cut -d: -f1 || true)"; \
        if [ -n "${existing_group}" ] && [ "${existing_group}" != "${USER}" ]; then \
          groupmod -n "${USER}" "${existing_group}"; \
        fi; \
        usermod -l "${USER}" -d "/home/${USER}" -m "${existing}"; \
      else \
        groupadd --gid "${GID}" "${USER}"; \
        useradd --uid "${UID}" --gid "${GID}" -m -s /bin/bash "${USER}"; \
      fi; \
    fi; \
    # Make sure the IDs match the host (covers the "different UID" case).
    current_uid="$(id -u "${USER}")"; \
    current_gid="$(id -g "${USER}")"; \
    if [ "${current_uid}" != "${UID}" ] || [ "${current_gid}" != "${GID}" ]; then \
      groupmod -g "${GID}" "${USER}" 2>/dev/null || true; \
      usermod -u "${UID}" -g "${GID}" "${USER}"; \
      chown -R "${UID}:${GID}" "/home/${USER}"; \
    fi; \
    # Ensure groups we care about exist and the dev user is in them.
    getent group dialout  >/dev/null || groupadd dialout; \
    getent group plugdev  >/dev/null || groupadd plugdev; \
    getent group sudo     >/dev/null || groupadd sudo; \
    usermod -aG dialout,sudo,plugdev "${USER}"; \
    echo "${USER} ALL=(ALL) NOPASSWD: ALL" > "/etc/sudoers.d/90-${USER}"; \
    chmod 0440 "/etc/sudoers.d/90-${USER}"

# --- Entrypoint sources the ROS overlay -------------------------------------
COPY entrypoints/ros-entrypoint.sh /usr/local/bin/ros-entrypoint.sh
RUN chmod +x /usr/local/bin/ros-entrypoint.sh

USER ${USER}
WORKDIR /workspace
SHELL ["/bin/bash", "-c"]

ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8

ENTRYPOINT ["/usr/local/bin/ros-entrypoint.sh"]
CMD ["bash"]
